---
import '../styles/global.css';
import { featuredPosts } from '../data/posts';
import { site } from '../data/site';

const title = 'West Coast Cyber Systems | Custom Software, AI Integration & Infrastructure Perth';
const description =
  'Perth technology consultancy helping Western Australian businesses customise software, integrate AI, deploy systems, improve CMS workflows and build practical infrastructure.';

const services = [
  {
    name: 'CMS And Website Systems',
    text: 'Set up, customise and improve content management systems so teams can update pages, publish content and manage enquiries without fighting the website.'
  },
  {
    name: 'Software Customisation',
    text: 'Adapt existing tools, portals, dashboards and workflows around the way the business actually runs instead of forcing staff through awkward manual processes.'
  },
  {
    name: 'Deployment And Releases',
    text: 'Move systems from idea to production with clean hosting, version control, testing, DNS, backups and repeatable release processes.'
  },
  {
    name: 'AI Integration',
    text: 'Connect AI into real business workflows for search, drafting, triage, reporting, customer response and internal knowledge without losing control of the process.'
  },
  {
    name: 'Infrastructure Foundations',
    text: 'Design and improve the cloud, server, network, identity and storage foundations that business software depends on.'
  },
  {
    name: 'Automation And Integration',
    text: 'Link forms, email, spreadsheets, databases, CRMs and line-of-business tools so information moves cleanly and repetitive admin drops away.'
  }
];

const sectors = [
  'Mining and resources suppliers',
  'Construction and trades',
  'Professional services',
  'Health and community providers',
  'Manufacturing and logistics',
  'Growing technology teams'
];

const process = [
  {
    step: 'See',
    title: 'Understand the business first',
    text: 'Map the systems, accounts, suppliers, data paths and workflows that matter most.'
  },
  {
    step: 'Fix',
    title: 'Close the highest-value gaps',
    text: 'Prioritise identity, cloud, endpoint, backup, network and process controls that reduce real exposure.'
  },
  {
    step: 'Build',
    title: 'Implement practical security systems',
    text: 'Put the right protections, workflows and AI-safe automations in place without overcomplicating the business.'
  },
  {
    step: 'Grow',
    title: 'Improve as the business changes',
    text: 'Review, tune and extend the security program as people, tools, suppliers and AI use cases evolve.'
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'West Coast Cyber Systems',
  url: site.url,
  image: `${site.url}${site.heroImage}`,
  description,
  email: site.contactEmail,
  telephone: site.contactPhoneHref,
  sameAs: [site.facebookUrl],
  areaServed: [
    {
      '@type': 'City',
      name: 'Perth'
    },
    {
      '@type': 'State',
      name: 'Western Australia'
    }
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Perth',
    addressRegion: 'WA',
    addressCountry: 'AU'
  },
  serviceType: [
    'Custom software consulting',
    'CMS implementation',
    'Software customisation',
    'AI integration',
    'System deployment',
    'Business infrastructure'
  ]
};
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#071015" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:site_name" content="West Coast Cyber Systems" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site.url} />
    <meta property="og:image" content={`${site.url}${site.fallbackHero}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.url}${site.fallbackHero}`} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <a class="brand" href="/" aria-label="West Coast Cyber Systems home">
        <span class="brand-mark">WC</span>
        <span class="brand-text">
          <span>West Coast</span>
          <span>Cyber Systems</span>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="#services">Services</a>
        <a href="#approach">Approach</a>
        <a href="/insights/">Insights</a>
        <a href="#perth">Perth</a>
        <a href="#contact">Contact</a>
      </nav>
      <a class="header-action" href="#contact">Start</a>
    </header>

    <main id="main">
      <section class="hero" aria-labelledby="hero-title">
        <picture class="hero-media">
          <source srcset={site.heroImage} type="image/webp" />
          <img
            src={site.fallbackHero}
            alt="Perth skyline with secure digital infrastructure and AI network overlays"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
        <div class="hero-shade" aria-hidden="true"></div>
        <div class="hero-signal" aria-hidden="true">
          <svg class="hero-flow" viewBox="0 0 1742 768" preserveAspectRatio="xMaxYMid slice" focusable="false">
            <defs>
              <filter id="hero-flow-bloom" x="-8%" y="-8%" width="116%" height="116%" color-interpolation-filters="sRGB">
                <feGaussianBlur in="SourceGraphic" stdDeviation="2.2" result="softGlow" />
                <feMerge>
                  <feMergeNode in="softGlow" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
            <g class="flow-pipes">
              <path d="M20 668 C155 640 270 620 386 630 C542 644 676 704 828 681 C958 661 1043 584 1175 559 C1306 534 1455 578 1722 560" />
              <path d="M78 724 C236 675 365 654 508 657 C655 661 762 630 888 574 C1019 516 1139 496 1262 512 C1394 530 1526 589 1722 610" />
              <path d="M536 602 C662 590 763 570 852 531 C958 485 1072 458 1182 470 C1290 482 1397 526 1518 524 C1607 523 1674 505 1722 487" />
              <path d="M396 248 L532 181 L652 264 L740 228 L858 284 L938 236 L1019 268" />
              <path d="M612 404 C697 368 760 372 828 416 C891 458 964 462 1042 430" />
            </g>
            <g class="flow-streams" filter="url(#hero-flow-bloom)">
              <path class="flow-line flow-line-a" pathLength="1000" d="M20 668 C155 640 270 620 386 630 C542 644 676 704 828 681 C958 661 1043 584 1175 559 C1306 534 1455 578 1722 560" />
              <path class="flow-line flow-line-b" pathLength="1000" d="M78 724 C236 675 365 654 508 657 C655 661 762 630 888 574 C1019 516 1139 496 1262 512 C1394 530 1526 589 1722 610" />
              <path class="flow-line flow-line-c" pathLength="1000" d="M536 602 C662 590 763 570 852 531 C958 485 1072 458 1182 470 C1290 482 1397 526 1518 524 C1607 523 1674 505 1722 487" />
              <path class="flow-line flow-line-d" pathLength="1000" d="M396 248 L532 181 L652 264 L740 228 L858 284 L938 236 L1019 268" />
              <path class="flow-line flow-line-e" pathLength="1000" d="M612 404 C697 368 760 372 828 416 C891 458 964 462 1042 430" />
            </g>
          </svg>
        </div>
        <div class="hero-inner">
          <p class="eyebrow">Perth, Western Australia</p>
          <h1 id="hero-title">West Coast Cyber Systems</h1>
          <p class="hero-copy">
            AI-assisted cyber security systems for businesses that need secure cloud, trusted identity,
            clear governance and practical resilience without enterprise theatre.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button button-primary" href="#contact">Plan a cyber systems review</a>
            <a class="button button-secondary" href="#services">Explore services</a>
          </div>
          <dl class="proof-strip" aria-label="Service focus">
            <div>
              <dt>Local</dt>
              <dd>Perth and WA focus</dd>
            </div>
            <div>
              <dt>AI</dt>
              <dd>Secure automation</dd>
            </div>
            <div>
              <dt>Systems</dt>
              <dd>Built to operate</dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="intro section-band" aria-labelledby="intro-title">
        <div class="section-grid">
          <div>
            <p class="section-kicker">Cyber security for operators</p>
            <h2 id="intro-title">Build security into the way the business actually runs.</h2>
          </div>
          <div class="intro-copy">
            <p>
              West Coast Cyber Systems helps Perth businesses move from scattered tools and one-off fixes
              to cyber systems that can be monitored, improved and explained.
            </p>
            <p>
              The focus is practical: protect identity, secure cloud platforms, make AI adoption safer,
              and give leaders a clear path for reducing risk without slowing useful work down.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="services" aria-labelledby="services-title">
        <div class="section-heading">
          <p class="section-kicker">Services</p>
          <h2 id="services-title">Custom systems for Perth businesses ready to move faster.</h2>
          <p>
            Practical software customisation, CMS improvement, deployment, AI integration and
            infrastructure support for businesses that need their systems to work together.
          </p>
        </div>
        <div class="service-grid">
          {
            services.map((service) => (
              <article class="service-card">
                <h3>{service.name}</h3>
                <p>{service.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section split-section" id="approach" aria-labelledby="approach-title">
        <div class="section-heading narrow">
          <p class="section-kicker">Approach</p>
          <h2 id="approach-title">A clear implementation path, not a tool wishlist.</h2>
          <p>
            Tools matter, but customers need outcomes first: safer access, stronger cloud controls,
            better resilience and a plan that makes sense to the people running the business.
          </p>
        </div>
        <div class="process-list">
          {
            process.map((item) => (
              <article class="process-item">
                <span>{item.step}</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section perth-section" id="perth" aria-labelledby="perth-title">
        <div class="perth-panel">
          <p class="section-kicker">Perth focus</p>
          <h2 id="perth-title">Built for Western Australian business conditions.</h2>
          <p>
            Perth organisations often run lean teams, distributed sites, critical suppliers and cloud-first
            systems. The right cyber security program has to fit that reality.
          </p>
        </div>
        <ul class="sector-list" aria-label="Industries served">
          {sectors.map((sector) => <li>{sector}</li>)}
        </ul>
      </section>

      <section class="section" id="insights" aria-labelledby="insights-title">
        <div class="section-heading">
          <p class="section-kicker">Insights</p>
          <h2 id="insights-title">Practical AI automation ideas for Perth businesses.</h2>
          <p>
            Guides on simplifying operations, integrating AI safely and building custom systems that
            help small and large businesses work with less friction.
          </p>
        </div>
        <div class="article-card-grid">
          {
            featuredPosts.map((post) => (
              <article class="article-card">
                <p class="article-meta">
                  <span>{post.category}</span>
                  <span>{post.readTime}</span>
                </p>
                <h3>
                  <a href={`/insights/${post.slug}/`}>{post.title}</a>
                </h3>
                <p>{post.description}</p>
                <a class="text-link" href={`/insights/${post.slug}/`}>Read article</a>
              </article>
            ))
          }
        </div>
        <div class="section-action">
          <a class="button button-dark" href="/insights/">View all insights</a>
        </div>
      </section>

      <section class="section contact-section" id="contact" aria-labelledby="contact-title">
        <div>
          <p class="section-kicker">Start here</p>
          <h2 id="contact-title">Start with a cyber systems review.</h2>
          <p>
            Start with a focused review of the systems, accounts, data, risks and AI use cases already
            inside the business. From there, build a staged plan for the security improvements that matter most.
          </p>
        </div>
        <div class="contact-box">
          <p class="contact-label">Contact</p>
          <a href={`mailto:${site.contactEmail}?subject=Cyber%20systems%20review`}>
            {site.contactEmail}
          </a>
          <a href={`tel:${site.contactPhoneHref}`}>
            {site.contactPhone}
          </a>
          <a href={site.facebookUrl} rel="me noopener noreferrer" target="_blank">
            Facebook
          </a>
          <p>
            Perth cyber security, AI systems, cloud hardening, identity security and resilience planning.
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
