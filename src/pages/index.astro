---
import '../styles/global.css';
import { featuredPosts } from '../data/posts';
import { site } from '../data/site';

const title = 'West Coast Cyber Systems | Practical Business Systems & AI Automation Perth';
const description =
  'Perth systems partner building practical business software, workflow automation and AI integrations that make daily work easier to manage.';

const services = [
  {
    name: 'CRM And Sales Pipeline',
    text: 'Keep every enquiry, customer, follow-up and opportunity in view so good work does not disappear into inboxes, notebooks or memory.'
  },
  {
    name: 'Quotes, Orders And Invoices',
    text: 'Turn the path from quote to order, invoice and payment into something clear enough for the whole business to trust.'
  },
  {
    name: 'Projects, Tasks And Time',
    text: 'Give jobs, tasks, time and service work a home so people know what is happening, what is waiting and what needs attention.'
  },
  {
    name: 'Products, Stock And Purchasing',
    text: 'Bring products, services, stock, purchases, shipments and suppliers out of scattered lists and into the flow of real work.'
  },
  {
    name: 'CMS, POS And Customer Touchpoints',
    text: 'Connect the places customers interact with you back to the team, so forms, sales and service moments become action instead of admin.'
  },
  {
    name: 'Integrations And Custom Modules',
    text: 'Adapt the system around the business with imports, exports, APIs and custom modules, while keeping the tools that already earn their place.'
  }
];

const sectors = [
  'Small business operators',
  'Trades and service businesses',
  'Professional services',
  'Local retailers and online sellers',
  'Contractors and field teams',
  'Growing teams moving beyond spreadsheets'
];

const process = [
  {
    step: 'See',
    title: 'Understand the business first',
    text: 'Find where time leaks out of the day: repeated entry, missing follow-ups, unclear jobs, scattered records and awkward handovers.'
  },
  {
    step: 'Fit',
    title: 'Choose the right modules',
    text: 'Start with the pieces that will make life easier fastest, from CRM and quoting through to projects, billing, stock, CMS and reporting.'
  },
  {
    step: 'Build',
    title: 'Build useful management systems',
    text: 'Configure, customise, deploy and connect the system so it supports real work instead of becoming another place to copy things into.'
  },
  {
    step: 'Grow',
    title: 'Improve as the business changes',
    text: 'Add automation, AI assistance, dashboards and custom modules only when they make the next part of the business easier to run.'
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'West Coast Cyber Systems',
  url: site.url,
  image: `${site.url}${site.heroImage}`,
  description,
  email: site.contactEmail,
  telephone: site.contactPhoneHref,
  sameAs: [site.facebookUrl],
  areaServed: [
    {
      '@type': 'City',
      name: 'Perth'
    },
    {
      '@type': 'State',
      name: 'Western Australia'
    }
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Perth',
    addressRegion: 'WA',
    addressCountry: 'AU'
  },
  serviceType: [
    'Business systems implementation',
    'CRM and operations systems',
    'Small business management systems',
    'Workflow automation',
    'AI integration',
    'Software customisation'
  ]
};
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#071015" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:site_name" content="West Coast Cyber Systems" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site.url} />
    <meta property="og:image" content={`${site.url}${site.fallbackHero}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.url}${site.fallbackHero}`} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <a class="brand" href="/" aria-label="West Coast Cyber Systems home">
        <span class="brand-mark">WC</span>
        <span class="brand-text">
          <span>West Coast</span>
          <span>Cyber Systems</span>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="#services">Services</a>
        <a href="#approach">Approach</a>
        <a href="/insights/">Insights</a>
        <a href="#perth">Perth</a>
        <a href="#contact">Contact</a>
      </nav>
      <a class="header-action" href="#contact">Start</a>
    </header>

    <main id="main">
      <section class="hero" aria-labelledby="hero-title">
        <picture class="hero-media">
          <source srcset={site.heroImage} type="image/webp" />
          <img
            src={site.fallbackHero}
            alt="Perth skyline with connected business systems and AI network overlays"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
        <div class="hero-shade" aria-hidden="true"></div>
        <div class="hero-signal" aria-hidden="true">
          <svg class="hero-flow" viewBox="0 0 1742 768" preserveAspectRatio="xMaxYMid slice" focusable="false">
            <defs>
              <filter id="hero-flow-bloom" x="-8%" y="-8%" width="116%" height="116%" color-interpolation-filters="sRGB">
                <feGaussianBlur in="SourceGraphic" stdDeviation="2.2" result="softGlow" />
                <feMerge>
                  <feMergeNode in="softGlow" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
            <g class="flow-pipes">
              <path d="M20 668 C155 640 270 620 386 630 C542 644 676 704 828 681 C958 661 1043 584 1175 559 C1306 534 1455 578 1722 560" />
              <path d="M78 724 C236 675 365 654 508 657 C655 661 762 630 888 574 C1019 516 1139 496 1262 512 C1394 530 1526 589 1722 610" />
              <path d="M536 602 C662 590 763 570 852 531 C958 485 1072 458 1182 470 C1290 482 1397 526 1518 524 C1607 523 1674 505 1722 487" />
              <path d="M396 248 L532 181 L652 264 L740 228 L858 284 L938 236 L1019 268" />
              <path d="M612 404 C697 368 760 372 828 416 C891 458 964 462 1042 430" />
            </g>
            <g class="flow-streams" filter="url(#hero-flow-bloom)">
              <path class="flow-line flow-line-a" pathLength="1000" d="M20 668 C155 640 270 620 386 630 C542 644 676 704 828 681 C958 661 1043 584 1175 559 C1306 534 1455 578 1722 560" />
              <path class="flow-line flow-line-b" pathLength="1000" d="M78 724 C236 675 365 654 508 657 C655 661 762 630 888 574 C1019 516 1139 496 1262 512 C1394 530 1526 589 1722 610" />
              <path class="flow-line flow-line-c" pathLength="1000" d="M536 602 C662 590 763 570 852 531 C958 485 1072 458 1182 470 C1290 482 1397 526 1518 524 C1607 523 1674 505 1722 487" />
              <path class="flow-line flow-line-d" pathLength="1000" d="M396 248 L532 181 L652 264 L740 228 L858 284 L938 236 L1019 268" />
              <path class="flow-line flow-line-e" pathLength="1000" d="M612 404 C697 368 760 372 828 416 C891 458 964 462 1042 430" />
            </g>
          </svg>
        </div>
        <div class="hero-inner">
          <p class="eyebrow">Perth, Western Australia</p>
          <h1 id="hero-title">West Coast Cyber Systems</h1>
          <p class="hero-copy">
            Practical business systems for Perth teams who want less chasing, clearer handovers
            and one place to see customers, jobs, billing and the next best action.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button button-primary" href="#contact">Make work easier</a>
            <a class="button button-secondary" href="#services">See what can improve</a>
          </div>
          <dl class="proof-strip" aria-label="Service focus">
            <div>
              <dt>Clearer</dt>
              <dd>Less chasing</dd>
            </div>
            <div>
              <dt>Connected</dt>
              <dd>CRM to billing</dd>
            </div>
            <div>
              <dt>Practical</dt>
              <dd>Built to use</dd>
            </div>
          </dl>
        </div>
      </section>

      <section class="intro section-band" aria-labelledby="intro-title">
        <div class="section-grid">
          <div>
            <p class="section-kicker">Business management systems</p>
            <h2 id="intro-title">Make the business easier to run without rebuilding it from scratch.</h2>
          </div>
          <div class="intro-copy">
            <p>
              Most businesses do not need another complicated app. They need the work they already
              do every day to move cleanly from one step to the next.
            </p>
            <p>
              West Coast Cyber Systems turns scattered tools, manual admin and one-off workarounds
              into a calmer operating flow: customers, quotes, orders, invoices, projects, products,
              stock, documents, CMS and reporting working together around the business.
            </p>
          </div>
        </div>
      </section>

      <section class="section" id="services" aria-labelledby="services-title">
        <div class="section-heading">
          <p class="section-kicker">Services</p>
          <h2 id="services-title">Useful systems for the parts of the business that cause friction.</h2>
          <p>
            Start where the day feels heavier than it should. WCCS helps choose the right pieces,
            connect them properly and add AI where it quietly removes busywork.
          </p>
        </div>
        <div class="service-grid">
          {
            services.map((service) => (
              <article class="service-card">
                <h3>{service.name}</h3>
                <p>{service.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section split-section" id="approach" aria-labelledby="approach-title">
        <div class="section-heading narrow">
          <p class="section-kicker">Approach</p>
          <h2 id="approach-title">Start with the work, then shape the system around it.</h2>
          <p>
            The goal is not to turn on every possible feature. It is to build a useful path from
            enquiry to quote, job, invoice, payment, follow-up and management reporting.
          </p>
        </div>
        <div class="process-list">
          {
            process.map((item) => (
              <article class="process-item">
                <span>{item.step}</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section perth-section" id="perth" aria-labelledby="perth-title">
        <div class="perth-panel">
          <p class="section-kicker">Perth focus</p>
          <h2 id="perth-title">Built for Western Australian business conditions.</h2>
          <p>
            Perth small businesses often run lean teams, busy owners, field work, suppliers,
            cloud tools and spreadsheets that have grown past their comfort zone. A good system
            should respect that reality: start small, connect what matters and grow only when it is useful.
          </p>
        </div>
        <ul class="sector-list" aria-label="Industries served">
          {sectors.map((sector) => <li>{sector}</li>)}
        </ul>
      </section>

      <section class="section" id="insights" aria-labelledby="insights-title">
        <div class="section-heading">
          <p class="section-kicker">Insights</p>
          <h2 id="insights-title">Practical AI automation ideas for Perth businesses.</h2>
          <p>
            Guides on simplifying operations, integrating AI, improving management workflows and
            building custom systems that help small businesses work with less friction.
          </p>
        </div>
        <div class="article-card-grid">
          {
            featuredPosts.map((post) => (
              <article class="article-card">
                <p class="article-meta">
                  <span>{post.category}</span>
                  <span>{post.readTime}</span>
                </p>
                <h3>
                  <a href={`/insights/${post.slug}/`}>{post.title}</a>
                </h3>
                <p>{post.description}</p>
                <a class="text-link" href={`/insights/${post.slug}/`}>Read article</a>
              </article>
            ))
          }
        </div>
        <div class="section-action">
          <a class="button button-dark" href="/insights/">View all insights</a>
        </div>
      </section>

      <section class="section contact-section" id="contact" aria-labelledby="contact-title">
        <div>
          <p class="section-kicker">Start here</p>
          <h2 id="contact-title">Start with where the day gets messy.</h2>
          <p>
            Talk through the repeated admin, missing information, clunky handovers and tools that do
            not quite fit anymore. From there, choose the right system changes to make management easier.
          </p>
        </div>
        <div class="contact-box">
          <p class="contact-label">Contact</p>
          <a href={`mailto:${site.contactEmail}?subject=Management%20system%20review`}>
            {site.contactEmail}
          </a>
          <a href={`tel:${site.contactPhoneHref}`}>
            {site.contactPhone}
          </a>
          <a href={site.facebookUrl} rel="me noopener noreferrer" target="_blank">
            Facebook
          </a>
          <p>
            Perth business management systems, AI automation, software customisation and practical deployment.
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
