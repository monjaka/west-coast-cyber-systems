---
import '../../styles/global.css';
import { posts, type BlogPost } from '../../data/posts';
import { site } from '../../data/site';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: BlogPost };
const pageUrl = `${site.url}/insights/${post.slug}/`;
const pageTitle = `${post.title} | West Coast Cyber Systems`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.description,
      image: `${site.url}${site.fallbackHero}`,
      datePublished: post.published,
      dateModified: post.updated,
      author: {
        '@type': 'Organization',
        name: site.name,
        url: site.url
      },
      publisher: {
        '@type': 'Organization',
        name: site.name,
        logo: {
          '@type': 'ImageObject',
          url: `${site.url}/favicon.svg`
        }
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': pageUrl
      },
      keywords: post.keywords.join(', '),
      articleSection: post.category
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: site.url
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Insights',
          item: `${site.url}/insights/`
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.title,
          item: pageUrl
        }
      ]
    },
    {
      '@type': 'FAQPage',
      mainEntity: post.faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer
        }
      }))
    }
  ]
};
const relatedPosts = posts.filter((item) => item.slug !== post.slug).slice(0, 3);
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={post.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#071015" />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={post.title} />
    <meta property="og:description" content={post.description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={`${site.url}${site.fallbackHero}`} />
    <meta property="article:published_time" content={post.published} />
    <meta property="article:modified_time" content={post.updated} />
    <meta property="article:section" content={post.category} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header" aria-label="Site header">
      <a class="brand" href="/" aria-label="West Coast Cyber Systems home">
        <span class="brand-mark">WC</span>
        <span class="brand-text">
          <span>West Coast</span>
          <span>Cyber Systems</span>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/#services">Services</a>
        <a href="/#approach">Approach</a>
        <a href="/insights/">Insights</a>
        <a href="/#contact">Contact</a>
      </nav>
      <a class="header-action" href="/#contact">Start</a>
    </header>

    <main id="main">
      <article>
        <header class="article-hero" aria-labelledby="article-title">
          <div class="article-hero-media" aria-hidden="true">
            <img src={site.fallbackHero} alt="" loading="eager" decoding="async" />
          </div>
          <div class="motion-grid" aria-hidden="true"></div>
          <div class="article-hero-inner">
            <p class="eyebrow">{post.category}</p>
            <h1 id="article-title">{post.title}</h1>
            <p>{post.description}</p>
            <p class="article-meta article-meta-light">
              <span>{new Date(post.published).toLocaleDateString('en-AU', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              })}</span>
              <span>{post.readTime}</span>
            </p>
          </div>
        </header>

        <div class="article-shell">
          <aside class="article-sidebar" aria-label="Article summary">
            <a class="text-link" href="/insights/">All insights</a>
            <div class="sidebar-panel">
              <p class="contact-label">Keywords</p>
              <ul>
                {post.keywords.map((keyword) => <li>{keyword}</li>)}
              </ul>
            </div>
          </aside>

          <div class="article-body">
            {post.intro.map((paragraph) => <p class="lead">{paragraph}</p>)}

            {
              post.sections.map((section) => (
                <section>
                  <h2>{section.heading}</h2>
                  {section.body.map((paragraph) => <p>{paragraph}</p>)}
                </section>
              ))
            }

            {
              post.checklist && (
                <section class="checklist-block" aria-labelledby="checklist-title">
                  <h2 id="checklist-title">Practical checklist</h2>
                  <ul>
                    {post.checklist.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              )
            }

            <section class="faq-block" aria-labelledby="faq-title">
              <h2 id="faq-title">Questions Perth businesses often ask</h2>
              {post.faqs.map((faq) => (
                <details>
                  <summary>{faq.question}</summary>
                  <p>{faq.answer}</p>
                </details>
              ))}
            </section>
          </div>
        </div>
      </article>

      <section class="section related-section" aria-labelledby="related-title">
        <div class="section-heading">
          <p class="section-kicker">Keep reading</p>
          <h2 id="related-title">Related AI automation insights.</h2>
        </div>
        <div class="article-card-grid compact">
          {
            relatedPosts.map((item) => (
              <article class="article-card">
                <p class="article-meta">
                  <span>{item.category}</span>
                  <span>{item.readTime}</span>
                </p>
                <h3>
                  <a href={`/insights/${item.slug}/`}>{item.title}</a>
                </h3>
                <p>{item.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section contact-section" aria-labelledby="article-contact-title">
        <div>
          <p class="section-kicker">Build the first workflow</p>
          <h2 id="article-contact-title">Start with a focused systems review.</h2>
          <p>
            Map the current workflow, identify the best automation opportunity and build a safer
            integration path before scaling AI across the business.
          </p>
        </div>
        <div class="contact-box">
          <p class="contact-label">Contact</p>
          <a href={`mailto:${site.contactEmail}?subject=AI%20automation%20review`}>
            {site.contactEmail}
          </a>
          <a href={`tel:${site.contactPhoneHref}`}>{site.contactPhone}</a>
          <a href={site.facebookUrl} rel="me noopener noreferrer" target="_blank">Facebook</a>
          <p>Perth AI automation, custom systems, workflow simplification and business management systems.</p>
        </div>
      </section>
    </main>
  </body>
</html>
